// Entrada de dados
let comando = "stop"; // Testando com stop
comando = comando.toLowerCase();

// Testando o comando
if (comando === "start") {
    console.log("Bot started");
} else if (comando === "stop") {
    console.log("Bot stopped"); // Corrigido de 'Bos' para 'Bot'
} else if (comando === "pause") {
    console.log("Bot paused");
} else {
    console.log("unknown command"); // Adicionado o ';' no final
}
